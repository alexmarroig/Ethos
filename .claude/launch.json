{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Frontend (Vite)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--workspace", "Frontend", "run", "dev"],
      "port": 8080,
      "autoPort": false
    },
    {
      "name": "ethos-clinic (Backend)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--workspace", "apps/ethos-clinic", "run", "dev"],
      "port": 8787
    },
    {
      "name": "ethos-control-plane",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--workspace", "apps/ethos-control-plane", "run", "dev"],
      "port": 8788
    },
    {
      "name": "ethos-desktop (Vite renderer)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--workspace", "apps/ethos-desktop", "run", "dev"],
      "port": 5173
    },
    {
      "name": "ethos-transcriber (worker)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--workspace", "apps/ethos-transcriber", "run", "dev"],
      "port": 0
    }
  ]
}
