{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",

    "moduleResolution": "node",
    "jsx": "react-jsx",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "types": ["node"],

    "rootDir": ".",
    "outDir": "dist",

    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true
  },
  "include": [
    "src",
    "electron"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "dist-electron",
    "../../apps/ethos-mobile"
  ]
}