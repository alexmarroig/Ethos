{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "src",
    "electron"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "dist-electron"
  ]
}
