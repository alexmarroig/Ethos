{
  "name": "ethos-mobile",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "npx tsc --noEmit",
    "build:android:apk": "npx eas-cli build -p android --profile preview",
    "build:android:aab": "npx eas-cli build -p android --profile release",
    "build:ios:testflight": "npx eas-cli build -p ios --profile ios-production",
    "submit:ios:testflight": "npx eas-cli submit -p ios --profile ios-production",
    "build:ios:simulator": "npx eas-cli build -p ios --profile ios-simulator",
    "build:web": "expo export --platform web && node ./scripts/postexport-pwa.mjs",
    "deploy:web": "npx eas-cli deploy",
    "build:android:apk:local": "npx expo prebuild --platform android --no-install --non-interactive && cd android && gradlew.bat assembleRelease"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.2.3",
    "@expo-google-fonts/lora": "^0.2.3",
    "@expo/metro-runtime": "~5.0.5",

    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/native-stack": "^6.9.17",

    "@sentry/react-native": "~6.14.0",

    "buffer": "^5.7.1",
    "crypto-js": "^4.2.0",

    "expo": "~53.0.0",
    "expo-av": "~15.1.7",
    "expo-blur": "~14.1.5",
    "expo-crypto": "~14.1.5",
    "expo-dev-client": "~5.2.4",
    "expo-device": "~7.1.4",
    "expo-document-picker": "~13.0.3",
    "expo-file-system": "~18.1.11",
    "expo-font": "~13.3.2",
    "expo-local-authentication": "~16.0.5",
    "expo-secure-store": "~14.2.4",
    "expo-sqlite": "~15.2.14",
    "expo-status-bar": "~2.2.0",
    "expo-notifications": "~0.31.0",
    "expo-sharing": "~13.0.0",
    "expo-print": "~13.0.0",
    "expo-background-fetch": "~13.0.0",
    "expo-task-manager": "~12.0.0",
    "expo-build-properties": "~0.14.7",
    "expo-web-browser": "~14.1.6",
    "react-native-calendars": "^1.1303.0",
    "react-native-blob-util": "^0.21.3",
    "react-native-pdf": "^6.7.6",

    "lucide-react-native": "^0.530.0",

    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.6",

    "react-native-device-info": "^15.0.1",
    "react-native-reanimated": "~3.17.0",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-svg": "15.11.2",
    "react-native-web": "^0.20.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "typescript": "~5.8.3",
    "workbox-build": "^7.3.0"
  },
  "private": true
}
