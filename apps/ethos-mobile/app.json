{
  "expo": {
    "name": "ETHOS",
    "slug": "ethos-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f0f5f6"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ethos.clinic",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "O Ethos precisa do microfone para gravar as sessões clínicas.",
        "NSFaceIDUsageDescription": "O Ethos usa biometria para proteger os dados clínicos.",
        "NSCameraUsageDescription": "O Ethos usa a câmera para digitalizar documentos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f0f5f6"
      },
      "package": "com.ethos.clinic",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.INTERNET"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      "expo-local-authentication",
      [
        "expo-av",
        {
          "microphonePermission": "O Ethos precisa do microfone para gravar sessões clínicas."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#234e5c",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "acf7b22f-889c-4233-8f82-f1ddc71984a7"
      }
    }
  }
}
