{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",

    "lib": ["ES2020", "DOM"],

    "moduleResolution": "node",
    "ignoreDeprecations": "5.0",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,

    "types": ["node"]
  }
}